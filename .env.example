# =======================
# DOCKER COMPOSE CONFIGURATION
# Copy this file to .env and update values
# =======================

# =======================
# DATABASE
# =======================
# For local development with Docker:
DATABASE_URL=postgresql://user:password@db:5432/gis_portal

# For Supabase (production):
# DATABASE_URL=postgresql://postgres.xxxxx:password@xxxxx.pooler.supabase.com:6543/postgres

# =======================
# BACKEND CONFIGURATION
# =======================
SECRET_KEY=your-secret-key-here-change-this-in-production
ENVIRONMENT=development
PYTHONUNBUFFERABLE=1

# =======================
# FRONTEND CONFIGURATION
# Backend service is accessible as 'backend' hostname in Docker network
# =======================
NEXT_PUBLIC_API_URL=http://backend:8000
NODE_ENV=development

# =======================
# LOCAL POSTGRESQL CONFIGURATION
# Only used when running local 'db' service in docker-compose
# =======================
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=gis_portal
