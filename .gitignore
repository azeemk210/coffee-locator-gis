# =======================
# ENVIRONMENT VARIABLES
# =======================
# Ignore ALL .env files from backend and frontend (contain secrets)
backend/.env*
frontend/.env*

# Root .env files
.env
.env.*.local
.env.production

# NOTE: Never commit .env files containing credentials!
# Copy .env.example or template files locally, then add secrets

# =======================
# PYTHON
# =======================
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# =======================
# NODE/NEXTJS
# =======================
node_modules/
.next/
out/
.vercel/

# =======================
# DATABASE
# =======================
*.sql
*.sqlite
*.db

# =======================
# IDE/OS
# =======================
.DS_Store
.vscode/settings.json
*.swp
*.swo
*~

